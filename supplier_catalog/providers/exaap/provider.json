{
  "provider_id": "exaap",
  "display_name": "Exaap",
  "website": "https://exaap.com/",
  "catalog_root_url": "https://exaap.com/",
  "access": {
    "type": "open",
    "requires_login": false,
    "read_only": true
  },
  "selectors": {
    "home_root": "https://exaap.com/",
    "catalog_note": "general product information only"
  },
  "data_precision": {
    "reference_codes": false,
    "vehicle_compatibility": false,
    "stock": false,
    "prices": false,
    "product_names": false,
    "detail_links": false,
    "image_urls": false,
    "descriptions": "general_only"
  },
  "matching": {
    "allowed_match_types": [
      "category_only",
      "manual_confirmation_required"
    ],
    "forbidden_match_types": [
      "exact_reference",
      "vehicle_compatible"
    ],
    "notes": "Very weak public signal. Keep it for manual verification only."
  },
  "daily_refresh": {
    "enabled": true,
    "local_time": "07:00",
    "timezone": "America/Bogota",
    "snapshot_path_pattern": "supplier_catalog/providers/exaap/snapshots/YYYY-MM-DD/",
    "outputs": [
      "extracted.json",
      "products.csv",
      "diff.json",
      "summary.md"
    ]
  }
}