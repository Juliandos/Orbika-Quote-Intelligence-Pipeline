{
  "provider_id": "totus",
  "display_name": "Totus",
  "website": "https://www.totus.com.co/",
  "catalog_root_url": "https://www.totus.com.co/productos-categoria/accesorios/",
  "access": {
    "type": "open",
    "requires_login": false,
    "read_only": true
  },
  "selectors": {
    "category_root": "https://www.totus.com.co/productos-categoria/accesorios/",
    "pagination_query_hint": "query pagination",
    "product_detail_path_hint": "/productos/"
  },
  "data_precision": {
    "reference_codes": false,
    "vehicle_compatibility": "partial",
    "stock": false,
    "prices": false,
    "product_names": true,
    "detail_links": true,
    "image_urls": true,
    "descriptions": "basic_or_partial"
  },
  "matching": {
    "allowed_match_types": [
      "vehicle_compatible",
      "category_only",
      "manual_confirmation_required"
    ],
    "forbidden_match_types": [
      "exact_reference"
    ],
    "notes": "Useful for accessories and electrical catalog comparison. Keep manual confirmation available when the detail page is sparse."
  },
  "daily_refresh": {
    "enabled": true,
    "local_time": "07:00",
    "timezone": "America/Bogota",
    "snapshot_path_pattern": "supplier_catalog/providers/totus/snapshots/YYYY-MM-DD/",
    "outputs": [
      "extracted.json",
      "products.csv",
      "diff.json",
      "summary.md"
    ]
  }
}