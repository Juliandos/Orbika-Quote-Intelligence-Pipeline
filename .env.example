# Local PostgreSQL for Orbika Phase 2.1.
# Copy values into a private .env if needed. Do not store real production secrets here.
ORBIKA_POSTGRES_DB=orbika_local
ORBIKA_POSTGRES_USER=orbika
ORBIKA_POSTGRES_PASSWORD=orbika_local_dev_password
ORBIKA_POSTGRES_PORT=5433

# Used by Alembic from WSL host.
DATABASE_URL=postgresql+psycopg://orbika:orbika_local_dev_password@localhost:5433/orbika_local

# API read store: json keeps the previous local file behavior; postgres reads from DATABASE_URL.
ORBIKA_API_STORE=json

# If a container needs DB access later, use the docker network hostname:
# DATABASE_URL=postgresql+psycopg://orbika:orbika_local_dev_password@db:5432/orbika_local
